    },
    {
      "name": "prioritize-backlog",
      "command": "node agents/tdf-label-creative/scripts/prioritize-backlog.js",
      "cwd": "/Users/diegosaa/GitHub/tdf-app",
      "dependsOn": ["generate-ideas"]
    },
    {
      "name": "analyze-experiments",
      "command": "node agents/tdf-label-creative/scripts/analyze-experiments.js",
      "cwd": "/Users/diegosaa/GitHub/tdf-app"
    }
  ],
  "reporting": {
    "outputDir": "/Users/diegosaa/.openclaw/orgs/tdf-label/reports",
