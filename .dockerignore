# Ignore Python cache files and directories
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Ignore virtual environments
.venv/
env/
venv/
ENV/

# Version metadata is injected with Docker build args; Git history is not
# needed by the image build.
.git/
.gitignore

# Ignore Docker-related files (keep Dockerfiles in the build context)
.dockerignore

# Ignore IDE/editor config files
.vscode/
.idea/
*.swp

# Ignore logs and temporary files
*.log
*.tmp
*.bak
*.swp
*.swo

# Ignore build artifacts
build/
dist/
*.egg-info/
.eggs/

# Ignore node_modules (if applicable)
node_modules/

# Ignore secrets and environment files
.env
.env.*
secrets/

# Ignore database files
*.db
*.sqlite3

# Ignore other unnecessary files
*.DS_Store
Thumbs.db

# Ignore large repo directories not needed for backend image builds
/archives/
/data/
/docs/
/screencast/
/tmp/
/streaming/
/tdf-hq-ui/
/tdf-hq-ui.backup.*/
/tdf-mobile/
/tidal-agent/

# Ignore SQL and DB init scripts (mounted as volumes, no need to include in build context)
sql/
db/

# Local Haskell and JavaScript build caches can exceed several gigabytes.
/.stack/
/.stack-root/
/node_modules/
/tdf-mobile/node_modules/
/tdf-hq-ui.backup.1762434604/node_modules/
/tdf-hq/.stack-root-local/
/tdf-hq/.stack-work/
/tdf-hq/dist-newstyle/
/tdf-hq/dist-newstyle-fno/
/tdf-hq-ui/node_modules/
