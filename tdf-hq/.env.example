# Contracts
PDF_BUCKET=s3://tdf-contracts
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# Stripe Configuration (Ticketing System)
# Get API keys from: https://dashboard.stripe.com/apikeys
# Get webhook secret from:  https://dashboard.stripe.com/webhooks
#
# Prefer a RESTRICTED key (rk_*) over a full secret key (sk_*) in production.
# Create one at https://dashboard.stripe.com/apikeys/create with permissions:
#   PaymentIntents: write, Customers: write, Refunds: write, Webhook Endpoints: read.
# Restricted keys authenticate identically to secret keys at the same endpoints.
STRIPE_SECRET_KEY=rk_test_your_restricted_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
