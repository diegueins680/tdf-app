ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,\
https://tdfui.pages.dev,https://tdf-app.pages.dev"
ALLOW_ALL_ORIGINS=false
CORS_DISABLE_DEFAULTS=false
# SEED_TRIGGER_TOKEN is intentionally unset by default (seeding endpoint disabled).
# Set to a strong random secret to enable: SEED_TRIGGER_TOKEN=<random-secret>
SEED_TRIGGER_TOKEN=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=tdf_hq
APP_PORT=8080
RESET_DB=false
SEED_DB=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret
PAYPAL_ENV=sandbox
# Datafast / OPPWA
DATAFAST_ENTITY_ID=your-entity-id
DATAFAST_BEARER_TOKEN=your-bearer-token
DATAFAST_BASE_URL=https://test.oppwa.com
DATAFAST_TEST_MODE=EXTERNAL
DATAFAST_MID=1000000505
DATAFAST_TID=PD100406
DATAFAST_PSERV=17913101
DATAFAST_USER_DATA2=Sismetic
DATAFAST_VERSIONDF=2

# Google Drive uploads (used by /drive/upload proxy)
# Preferred (recommended): refresh token + client credentials.
# You can also provide GOOGLE_CLIENT_ID/GOOGLE_CLIENT_SECRET instead of DRIVE_CLIENT_*.
DRIVE_REFRESH_TOKEN=
DRIVE_CLIENT_ID=
DRIVE_CLIENT_SECRET=
# Fallback (not recommended): short-lived access token.
DRIVE_ACCESS_TOKEN=
# Optional target folder ID in Drive
DRIVE_UPLOAD_FOLDER_ID=

# LLM provider defaults are centralized in TDF.Config.llmProvider.
# Set OPENAI_API_KEY for OpenAI; leave model/base unset unless overriding locally.
OPENAI_API_KEY=
CHATKIT_WORKFLOW_ID=
# OPENAI_MODEL=
# OPENAI_EMBED_MODEL=
# CHATKIT_API_BASE=
RAG_TOP_K=8
RAG_CHUNK_WORDS=220
RAG_CHUNK_OVERLAP=40
RAG_AVAILABILITY_DAYS=14
RAG_AVAILABILITY_PER_RESOURCE=6
RAG_REFRESH_HOURS=24
RAG_EMBED_BATCH_SIZE=64

# Daily Ticketmaster discovery for cities attached to active TDF users.
EVENT_DISCOVERY_ENABLED=true
TICKETMASTER_API_KEY=
TICKETMASTER_API_BASE=https://app.ticketmaster.com/discovery/v2
EVENT_DISCOVERY_LOOKAHEAD_DAYS=90
EVENT_DISCOVERY_MAX_PAGES_PER_CITY=5
EVENT_DISCOVERY_HOUR_LOCAL=3
# Optional deployment-wide country scope. Leave blank for users in multiple countries.
EVENT_DISCOVERY_COUNTRY_CODE=

# Instagram / Facebook Graph
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_GRAPH_BASE=https://graph.facebook.com/v20.0
FACEBOOK_MESSAGING_TOKEN=
FACEBOOK_MESSAGING_PAGE_ID=
FACEBOOK_MESSAGING_API_BASE=https://graph.facebook.com/v20.0
INSTAGRAM_GRAPH_BASE=https://graph.facebook.com/v20.0
INSTAGRAM_APP_TOKEN=
# Optional fallback token/account for /instagram/reply.
# If omitted, the API will try to use the connected SocialSyncAccount token
# resolved from the inbound message asset metadata (recipient_id/source_id).
INSTAGRAM_MESSAGING_TOKEN=
INSTAGRAM_MESSAGING_ACCOUNT_ID=
INSTAGRAM_MESSAGING_API_BASE=https://graph.facebook.com/v20.0
INSTAGRAM_VERIFY_TOKEN=
