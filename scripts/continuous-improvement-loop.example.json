{
  "ideaCommand": "node scripts/discover-improvement-idea.mjs",
  "implementationCommand": "./scripts/replace-with-your-implementer.sh {idea_file}",
  "uiFixCommand": "./scripts/replace-with-your-implementer.sh {ui_report_file}",
  "formalFixCommand": "./scripts/replace-with-your-implementer.sh {formal_report_file}",
