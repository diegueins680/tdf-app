# Local-only defaults for the Meta App Review screencast runner.
# Copy this file to a private env file or export the values manually before recording.
# Never commit real reviewer credentials or personal account details.

TDF_REVIEW_URL=https://tdf-app.pages.dev/social/instagram?review=1
TDF_REVIEW_INBOX_URL=https://tdf-app.pages.dev/social/inbox?review=1
TDF_REVIEW_USERNAME=admin
TDF_REVIEW_PASSWORD=password123
TDF_REVIEW_INBOUND_TEXT=Meta review inbound marker <timestamp> - from IG native client
TDF_REVIEW_SPOTLIGHT=1
TDF_REVIEW_SPOTLIGHT_MS=1200
TDF_SCREENCAST_OUT_DIR=screencast/meta-app-review/output
